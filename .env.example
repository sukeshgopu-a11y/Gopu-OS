# Supabase frontend env. Public anon/publishable keys only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Vite compatibility aliases. Keep these in sync with NEXT_PUBLIC_* values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key
VITE_SUPABASE_PUBLISHABLE_KEY=

# Resend live delivery verification. Server-side only: never expose this as VITE_*.
# If using onboarding@resend.dev, Resend only allows sending to the Resend account email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=GOPU Export OS <verified@example.com>
RESEND_TEST_TO=
LEAD_ADMIN_EMAIL=
RESEND_E2E_DEADLINE_MS=30000

# Founder-level Slack operational alerts. Server-side only: never expose this as VITE_*.
SLACK_WEBHOOK_URL=
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=C0B692ZMGSZ
SLACK_CHANNEL_NAME_FOR_DISPLAY=#all-gopu-os
# Slack interactive CMO approvals use /api/slack/cmo-actions as the interactivity request URL.
# Required bot scope for direct Block Kit sends: chat:write.
# Optional verification scopes: channels:read for public channels, groups:read for private channels.
SLACK_WORKSPACE_ID=

# Vercel Cron trigger auth. Server-side only.
SCHEDULER_RUNTIME=vercel_cron
CRON_SECRET=
CRON_TRIGGER_WINDOW_MINUTES=10

# CTO Vercel integration check. Server-side only: never expose this as VITE_*.
# If deployed on Vercel, runtime variables can verify hosting presence.
# Add VERCEL_TOKEN for live REST API verification, and VERCEL_PROJECT_ID for project-specific checks.
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_PROJECT_NAME=
VERCEL_TEAM_ID=

# External Redis for production queues/workers. Prefer Upstash Redis TCP URL for BullMQ workers.
REDIS_URL=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Supabase Storage is the default media storage provider for GOPU OS.
# Used for poster assets, generated images, approval previews, and published post media.
SUPABASE_STORAGE_BUCKET=cmo-generated-assets

# Optional/future only: Cloudflare R2 / S3-compatible storage. Server-side only.
# Leave blank unless GOPU OS is intentionally migrated from Supabase Storage to R2.
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_BUCKET=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_PUBLIC_BASE_URL=

# CTO provider vault. Server-side only. CMO consumes status from this CTO-owned source.
CTO_PROVIDER_OPENAI_API_KEY=
OPENAI_API_KEY=
OPENAI_CONTENT_PREMIUM_MODEL=gpt-5.5
OPENAI_CONTENT_FAST_MODEL=gpt-5.5
OPENAI_SUMMARY_MODEL=gpt-5.5
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=gpt-image-1
CTO_PROVIDER_HEYGEN_API_KEY=
HEYGEN_API_KEY=
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_URN=
YOUTUBE_API_KEY=
FOREX_API_KEY=
NEWS_API_KEY=

# Learning Centre research ingestion. Server-side only.
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
LEARNING_CENTRE_CYCLE_MINUTES=15
LEARNING_CENTRE_CONSOLIDATION_EVERY_N=5
LEARNING_CENTRE_FETCH_TIMEOUT_MS=10000
LEARNING_CENTRE_FETCH_MAX_BYTES=1048576
STOP_LEARNING_CENTRE=false

# Founder WhatsApp approval flow. Server-side only: never expose these as VITE_*.
# Supports Twilio, Meta WhatsApp Cloud API, and future provider proxy URLs.
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER=

# Supabase server env. Must use the same project ref as VITE_SUPABASE_URL.
# Never expose SUPABASE_SERVICE_ROLE_KEY in frontend or VITE_* variables.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-server-service-role-key

# One-time founder account bootstrap. Server/admin shell only; never expose as VITE_*.
FOUNDER_BOOTSTRAP_EMAIL=
FOUNDER_BOOTSTRAP_PASSWORD=
FOUNDER_BOOTSTRAP_NAME=GOPU Director
